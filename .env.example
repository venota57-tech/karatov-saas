APP_LOGIN=admin
APP_PASSWORD=change-me
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
WB_API_TOKEN=

# Публикация в WB. Для реальной ручной публикации поставь true и перезапусти.
# Автопубликация дополнительно требует включения правила в интерфейсе “Правила ИИ”.
ENABLE_MARKETPLACE_PUBLISHING=false

# WB sync mode: both / unanswered / answered
WB_SYNC_MODE=both

# Безопасные настройки против WB global limiter.
WB_SYNC_TAKE=100
WB_SYNC_MAX_PAGES=20
# За один проход исторического блока забираем только 1 страницу.
WB_SYNC_PAGES_PER_BLOCK_RUN=1

# v2.4: автоматическая синхронизация без ручных нажатий.
WB_AUTO_SYNC_ENABLED=true
WB_AUTO_SYNC_STRATEGY=dual_drip
WB_AUTO_SYNC_INITIAL_DELAY_SECONDS=20

# Операционная очередь: отзывы/вопросы без ответа, обновлять чаще.
WB_OPERATIONAL_SYNC_ENABLED=true
WB_OPERATIONAL_SYNC_INTERVAL_SECONDS=600

# Историческая догрузка: отзывы с ответом, вопросы с ответом, архив отзывов.
# Идет автоматически, по одной странице за проход, чтобы не ловить 429.
WB_BACKFILL_SYNC_ENABLED=true
WB_BACKFILL_SYNC_INTERVAL_SECONDS=1800
WB_BACKFILL_INITIAL_DELAY_SECONDS=180

# Старый общий интервал оставлен для совместимости.
WB_AUTO_SYNC_INTERVAL_SECONDS=900
WB_RATE_LIMIT_COOLDOWN_SECONDS=1800

WB_RETRY_ATTEMPTS=1
WB_RETRY_BASE_DELAY_SECONDS=10
WB_REQUEST_PAUSE_SECONDS=5
WB_REQUEST_TIMEOUT_SECONDS=25
WB_SYNC_MAX_RUNTIME_SECONDS=900

# Count-запросы WB выключены, потому что они ловили 429/timeout и не нужны для импорта.
WB_DIAGNOSTIC_COUNTS_ENABLED=false
WB_FEEDBACK_COUNT_DIAGNOSTICS_ENABLED=false

AI_AUTO_CLASSIFY_ON_SYNC=true

# Ozon Seller API
OZON_SYNC_ENABLED=false
OZON_CLIENT_ID=
OZON_API_KEY=
OZON_SYNC_TAKE=100
OZON_REQUEST_TIMEOUT_SECONDS=30
OZON_REQUEST_PAUSE_SECONDS=2


# Ozon auto sync: one Ozon block per interval, separate from WB.
OZON_AUTO_SYNC_ENABLED=false
OZON_AUTO_SYNC_INTERVAL_SECONDS=900
OZON_AUTO_SYNC_INITIAL_DELAY_SECONDS=40

# FBO autobooking / уведомления
# Для модуля автобронирования достаточно WB_API_TOKEN с категорией "Поставки".
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email-уведомления. Можно оставить пустым, если сначала используешь только Telegram и интерфейс.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM=
EMAIL_TO=

# Файл состояния календаря/логов FBO внутри backend-контейнера.
FBO_BOOKING_STATE_PATH=/app/fbo_booking_state.json


# FBO hybrid mode / POSTAVLENO radar
# POSTAVLENO is used as a radar only; final booking is done via WB cabinet/Playwright adapter.
FBO_POSTAVLENO_ENABLED=true
# Human label shown in UI. Real Telegram user-session will be connected in the next adapter.
FBO_POSTAVLENO_ACCOUNT_LABEL=
FBO_POSTAVLENO_SESSION_ALIAS=default

# Telegram user-session для чтения @POSTAVLENOru_BOT.
# API_ID/API_HASH получаются на my.telegram.org → API development tools.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
TELEGRAM_SESSION_DIR=/app/telegram_sessions

# FBO / Telegram Web Playwright
TELEGRAM_WEB_PROFILE_DIR=/app/playwright_profiles/telegram_web_postavleno
TELEGRAM_WEB_SCREENSHOT=/app/playwright_profiles/telegram_web_postavleno_last.png

# FBO WB-cabinet autopilot
FBO_BOOKING_STATE_PATH=/app/fbo_booking_state.json
WB_CABINET_PROFILE_DIR=/app/playwright_profiles/wb_cabinet
WB_CABINET_SCREENSHOT=/app/playwright_profiles/wb_cabinet_last.png
